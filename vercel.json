{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" }
  ],
  "rewrites": [
    { "source": "/public/(.*)", "destination": "/public/$1" },
    { "source": "/results.html", "destination": "/results.html" },
    { "source": "/library.html", "destination": "/library.html" },
    { "source": "/settings.html", "destination": "/settings.html" },
    { "source": "/test.html", "destination": "/test.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
